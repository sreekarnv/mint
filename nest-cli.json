{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "monorepo": true,
  "root": "apps",
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "fraud": {
      "type": "application",
      "root": "apps/fraud",
      "entryFile": "main",
      "sourceRoot": "apps/fraud/src",
      "compilerOptions": {
        "tsConfigPath": "apps/fraud/tsconfig.app.json",
        "webpackConfigPath": "apps/fraud/webpack.config.js"
      }
    },
    "transactions": {
      "type": "application",
      "root": "apps/transactions",
      "entryFile": "main",
      "sourceRoot": "apps/transactions/src",
      "compilerOptions": {
        "tsConfigPath": "apps/transactions/tsconfig.app.json",
        "webpackConfigPath": "apps/transactions/webpack.config.js"
      }
    }
  },
  "watchOptions": {
    "usePolling": true,
    "interval": 1000
  }
}
{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default"
      ]
    },
    "test": {
      "inputs": [
        "default"
      ]
    },
    "lint": {
      "inputs": [
        "default"
      ]
    }
  },
  "analytics": false
}
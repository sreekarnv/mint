<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify your email - Mint</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #f4f4f5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .wrapper {
      max-width: 560px;
      margin: 40px auto;
      background: #fff;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0, 0, 0, .08);
    }

    .header {
      background: #18181b;
      padding: 28px 32px;
    }

    .header h1 {
      margin: 0;
      color: #fff;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: -0.3px;
    }

    .body {
      padding: 32px;
    }

    .body h2 {
      margin: 0 0 12px;
      color: #18181b;
      font-size: 18px;
      font-weight: 600;
    }

    .body p {
      margin: 0 0 16px;
      color: #3f3f46;
      font-size: 15px;
      line-height: 1.6;
    }

    .btn-wrap {
      margin: 28px 0;
    }

    .btn {
      display: inline-block;
      background: #18181b;
      color: #fff !important;
      text-decoration: none;
      padding: 13px 28px;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 500;
    }

    .divider {
      border: none;
      border-top: 1px solid #e4e4e7;
      margin: 24px 0;
    }

    .fallback {
      font-size: 12px;
      color: #a1a1aa;
      word-break: break-all;
      line-height: 1.6;
    }

    .expire-note {
      font-size: 13px;
      color: #71717a;
      margin: 0;
    }

    .footer {
      padding: 20px 32px;
      border-top: 1px solid #f4f4f5;
    }

    .footer p {
      margin: 0;
      font-size: 13px;
      color: #a1a1aa;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>Mint</h1>
    </div>
    <div class="body">
      <h2>Verify your email address</h2>
      <p>Hi {{ name }},</p>
      <p>Thanks for signing up. Click the button below to verify your email address and activate your Mint account.</p>
      <div class="btn-wrap">
        <a href="{{ url }}" class="btn">Verify Email</a>
      </div>
      <p class="expire-note">This link expires in {{ (expires_in_minutes / 60) | int }} hour{% if (expires_in_minutes / 60) | int != 1 %}s{% endif %}. If it has expired, you can request a new one from the app.</p>
      <hr class="divider" />
      <p class="fallback">If the button doesn't work, copy and paste this URL into your browser:<br />{{ url }}</p>
    </div>
    <div class="footer">
      <p>&copy; 2026 Mint. If you didn't create an account, you can safely ignore this email.</p>
    </div>
  </div>
</body>
</html>

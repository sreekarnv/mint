<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Transfer Sent - Mint</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #f4f4f5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .wrapper {
      max-width: 560px;
      margin: 40px auto;
      background: #fff;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0, 0, 0, .08);
    }

    .header {
      background: #18181b;
      padding: 28px 32px;
    }

    .header h1 {
      margin: 0;
      color: #fff;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: -0.3px;
    }

    .body {
      padding: 32px;
    }

    .amount-block {
      background: #fafafa;
      border: 1px solid #e4e4e7;
      border-radius: 8px;
      padding: 20px 24px;
      margin: 20px 0;
      text-align: center;
    }

    .amount-block .amount {
      font-size: 32px;
      font-weight: 700;
      color: #18181b;
      letter-spacing: -1px;
    }

    .amount-block .currency {
      font-size: 14px;
      color: #71717a;
      margin-top: 4px;
    }

    .body p {
      margin: 0 0 16px;
      color: #3f3f46;
      font-size: 15px;
      line-height: 1.6;
    }

    .meta {
      font-size: 13px;
      color: #71717a;
      font-family: 'JetBrains Mono', monospace;
    }

    .footer {
      padding: 20px 32px;
      border-top: 1px solid #f4f4f5;
    }

    .footer p {
      margin: 0;
      font-size: 13px;
      color: #a1a1aa;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>Mint</h1>
    </div>
    <div class="body">
      <p>Your transfer was sent successfully.</p>
      <div class="amount-block">
        <div class="amount"><%= amount %> <span style="font-size:20px;font-weight:500"><%= currency %></span></div>
      </div>
      <% if (description) { %>
        <p>Description: <strong><%= description %></strong></p>
      <% } %>
      <p class="meta">Transaction ID: <%= transactionId %></p>
    </div>
    <div class="footer">
      <p>&copy; <%= new Date().getFullYear() %> Mint. If you didn't make this transfer, contact support immediately.</p>
    </div>
  </div>
</body>
</html>

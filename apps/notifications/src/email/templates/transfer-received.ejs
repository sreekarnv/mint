<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Transfer Received - Mint</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #f4f4f5;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .wrapper {
      max-width: 560px;
      margin: 40px auto;
      background: #fff;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0, 0, 0, .08);
    }

    .header {
      background: #18181b;
      padding: 28px 32px;
    }

    .header h1 {
      margin: 0;
      color: #fff;
      font-size: 20px;
      font-weight: 600;
      letter-spacing: -0.3px;
    }

    .body {
      padding: 32px;
    }

    .body h2 {
      margin: 0 0 12px;
      color: #18181b;
      font-size: 18px;
      font-weight: 600;
    }

    .body p {
      margin: 0 0 16px;
      color: #3f3f46;
      font-size: 15px;
      line-height: 1.6;
    }

    .badge {
      display: inline-block;
      background: #f0fdf4;
      color: #15803d;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      padding: 4px 12px;
      border-radius: 99px;
      border: 1px solid #bbf7d0;
      margin-bottom: 16px;
    }

    .stat-card {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 8px;
      padding: 24px;
      margin: 20px 0;
      text-align: center;
    }

    .stat-label {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #15803d;
      margin-bottom: 8px;
      opacity: 0.8;
    }

    .stat-amount {
      font-size: 36px;
      font-weight: 700;
      color: #15803d;
      letter-spacing: -1.5px;
      line-height: 1;
    }

    .stat-currency {
      font-size: 15px;
      font-weight: 500;
      color: #15803d;
      margin-top: 6px;
      opacity: 0.7;
    }

    .divider {
      border: none;
      border-top: 1px solid #e4e4e7;
      margin: 20px 0;
    }

    .meta-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }

    .meta-key {
      font-size: 13px;
      color: #71717a;
    }

    .meta-val {
      font-size: 13px;
      color: #3f3f46;
      font-weight: 500;
    }

    .meta-id {
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
      font-size: 12px;
      color: #71717a;
      word-break: break-all;
    }

    .footer {
      padding: 20px 32px;
      border-top: 1px solid #f4f4f5;
    }

    .footer p {
      margin: 0;
      font-size: 13px;
      color: #a1a1aa;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>Mint</h1>
    </div>
    <div class="body">
      <span class="badge">Received</span>
      <h2>Money Received</h2>
      <p>A transfer has been credited to your Mint wallet.</p>
      <div class="stat-card">
        <div class="stat-label">Amount Received</div>
        <div class="stat-amount"><%= amount %></div>
        <div class="stat-currency"><%= currency %></div>
      </div>
      <% if (description) { %>
        <hr class="divider" />
        <div class="meta-row">
          <span class="meta-key">Description</span>
          <span class="meta-val"><%= description %></span>
        </div>
      <% } %>
      <hr class="divider" />
      <div class="meta-row">
        <span class="meta-key">Transaction ID</span>
      </div>
      <p class="meta-id"><%= transactionId %></p>
    </div>
    <div class="footer">
      <p>&copy; <%= new Date().getFullYear() %> Mint. Funds are now available in your wallet.</p>
    </div>
  </div>
</body>
</html>

{
  "name": "mint",
  "version": "2.0.0",
  "description": "",
  "author": "Sreekar Venkata Nutulapati",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "dev:transactions": "nest start --watch transactions",
    "migrate:transactions": "prisma migrate deploy --config apps/transactions/prisma.config.ts",
    "migrate:transactions:dev": "prisma migrate dev --config apps/transactions/prisma.config.ts",
    "generate:transactions": "prisma generate --config apps/transactions/prisma.config.ts",
    "start:dev:fraud": "nest start --watch fraud",
    "dev:fraud": "pnpm run generate:fraud && pnpm run start:dev:fraud",
    "migrate:fraud:dev": "prisma migrate dev --config apps/fraud/prisma.config.ts",
    "migrate:fraud": "prisma migrate deploy --config apps/fraud/prisma.config.ts",
    "generate:fraud": "prisma generate --config apps/fraud/prisma.config.ts",
    "start:dev:kyc": "nest start --watch kyc",
    "dev:kyc": "pnpm run generate:kyc && pnpm run start:dev:kyc",
    "migrate:kyc:dev": "prisma migrate dev --config apps/kyc/prisma.config.ts",
    "migrate:kyc": "prisma migrate deploy --config apps/kyc/prisma.config.ts",
    "generate:kyc": "prisma generate --config apps/kyc/prisma.config.ts",
    "start:dev:analytics": "nest start --watch analytics",
    "dev:analytics": "pnpm run generate:analytics && pnpm run start:dev:analytics",
    "migrate:analytics:dev": "prisma migrate dev --config apps/analytics/prisma.config.ts",
    "migrate:analytics": "prisma migrate deploy --config apps/analytics/prisma.config.ts",
    "generate:analytics": "prisma generate --config apps/analytics/prisma.config.ts",
    "start:dev:notifications": "nest start --watch notifications",
    "dev:notifications": "pnpm run generate:notifications && pnpm run start:dev:notifications",
    "migrate:notifications:dev": "prisma migrate dev --config apps/notifications/prisma.config.ts",
    "migrate:notifications": "prisma migrate deploy --config apps/notifications/prisma.config.ts",
    "generate:notifications": "prisma generate --config apps/notifications/prisma.config.ts",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/mint/main",
    "start": "nest start",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/mint/test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs/bullmq": "^11.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.17",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bullmq": "^5.73.0",
    "cookie-parser": "^1.4.7",
    "geoip-lite": "^2.0.1",
    "ejs": "^3.1.10",
    "nodemailer": "^6.10.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "kafkajs": "^2.2.4",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/nodemailer": "^6.4.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^11.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@mint/common(|/.*)$": "<rootDir>/libs/common/src/$1"
    }
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}